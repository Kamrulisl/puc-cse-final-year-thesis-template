{
  "latex-workshop.latex.outDir": "build",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-pdf",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-outdir=.",
        "-auxdir=build",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (build folder)",
      "tools": [
        "latexmk"
      ]
    }
  ],
  "latex-workshop.latex.recipe.default": "latexmk (build folder)"
}
